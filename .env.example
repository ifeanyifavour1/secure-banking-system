# Copy to project/.env and fill in values from Neon (Dashboard → Connection details → .NET)
ConnectionStrings__neondb=Host=YOUR-ENDPOINT.pooler.us-east-1.aws.neon.tech;Database=neondb;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

Jwt__Secret=your-base64-or-long-secret-at-least-32-chars
API_BASE_URL=http://localhost:5285
FLASK_SECRET_KEY=local-dev-flask-session-key
Admin__RoleAssignmentSecret=change-me-local-admin-secret

# Optional: only used if ConnectionStrings__neondb is empty (must be a real Neon URL, not a placeholder)
# DATABASE_URL=postgresql://user:password@YOUR-ENDPOINT.neon.tech/neondb?sslmode=require
